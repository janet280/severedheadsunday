# During `docker compose build`, these are passed as Docker build-args (see docker-compose.yml).
# Public MinIO/S3 endpoint for audio + optional background image (no trailing slash).
# Example local profile: http://localhost:9000/media
VITE_MEDIA_BASE_URL=

# Full URL to alley_background.jpg when hosted on S3/CloudFront.
VITE_BACKGROUND_IMAGE_URL=

WEB_PORT=8080

# docker compose --profile s3-local
MINIO_ROOT_USER=localkey
MINIO_ROOT_PASSWORD=localsecret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MEDIA_BUCKET=media
